/* app.wxss - 全局样式 */

/* 色彩变量 */
page {
  --primary: #FF6B35;
  --primary-light: #FF8B5E;
  --secondary: #F7C59F;
  --bg: #FFF8F3;
  --card-bg: #FFFFFF;
  --text-main: #333333;
  --text-sub: #666666;
  --text-hint: #999999;
  --border: #FFE8D6;
  --danger: #E74C3C;
  --success: #27AE60;

  background-color: var(--bg);
  color: var(--text-main);
  font-size: 28rpx;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Microsoft YaHei', sans-serif;
  box-sizing: border-box;
}

/* 通用容器 */
.container {
  padding: 24rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

/* 卡片 */
.card {
  background: var(--card-bg);
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 53, 0.08);
}

/* 标题 */
.title-lg {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-main);
}

.title-md {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-main);
}

.title-sm {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-main);
}

/* 辅助文字 */
.text-hint {
  font-size: 24rpx;
  color: var(--text-hint);
}

.text-sub {
  font-size: 28rpx;
  color: var(--text-sub);
}

/* 按钮 */
.btn-primary {
  background: linear-gradient(135deg, #FF6B35, #FF8B5E);
  color: #FFFFFF;
  border: none;
  border-radius: 48rpx;
  padding: 20rpx 48rpx;
  font-size: 30rpx;
  font-weight: 600;
  text-align: center;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.btn-primary::after {
  border: none;
}

.btn-secondary {
  background: var(--secondary);
  color: #FFFFFF;
  border: none;
  border-radius: 48rpx;
  padding: 20rpx 48rpx;
  font-size: 30rpx;
  font-weight: 600;
}

.btn-secondary::after {
  border: none;
}

.btn-outline {
  background: transparent;
  color: var(--primary);
  border: 2rpx solid var(--primary);
  border-radius: 48rpx;
  padding: 18rpx 46rpx;
  font-size: 30rpx;
}

.btn-outline::after {
  border: none;
}

/* 标签 */
.tag {
  display: inline-block;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  background: rgba(255, 107, 53, 0.1);
  color: var(--primary);
  margin-right: 12rpx;
}

.tag-secondary {
  background: rgba(247, 197, 159, 0.3);
  color: #D4885F;
}

/* flex 布局 */
.flex-row {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.flex-col {
  display: flex;
  flex-direction: column;
}

.flex-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-1 {
  flex: 1;
}

/* 头像 */
.avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: var(--secondary);
}

.avatar-sm {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
}

.avatar-lg {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
}

/* 分割线 */
.divider {
  height: 1rpx;
  background: var(--border);
  margin: 24rpx 0;
}

/* 空隙 */
.gap-sm { height: 16rpx; }
.gap-md { height: 24rpx; }
.gap-lg { height: 32rpx; }

/* 浮动按钮 */
.fab {
  position: fixed;
  right: 40rpx;
  bottom: 200rpx;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FF6B35, #FF8B5E);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 53, 0.35);
  z-index: 100;
}

.fab-text {
  color: #FFFFFF;
  font-size: 56rpx;
  font-weight: 300;
  line-height: 1;
}

/* 段落标题 */
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-header .title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-main);
}

.section-header .more {
  font-size: 24rpx;
  color: var(--text-hint);
}

/* 安全区域底部 */
.safe-bottom {
  height: env(safe-area-inset-bottom);
}
