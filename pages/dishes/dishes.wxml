<!-- pages/dishes/dishes.wxml -->
<view class="container">
  <!-- 搜索栏 -->
  <view class="search-bar">
    <view class="search-input-wrap">
      <text class="search-icon">🔍</text>
      <input class="search-input" placeholder="搜索菜品名称、食材" value="{{keyword}}" bindinput="onSearchInput" confirm-type="search" bindconfirm="onSearchConfirm"></input>
      <text class="search-clear" wx:if="{{keyword}}" bind:tap="clearSearch">✕</text>
    </view>
    <view class="batch-toggle" bind:tap="randomPick">
      <text>🎲</text>
    </view>
    <view class="batch-toggle" bind:tap="toggleTrash" wx:if="{{canManageDishes}}">
      <text>{{showTrash ? '✕关闭' : '🗑回收'}}</text>
    </view>
    <view class="batch-toggle" bind:tap="{{batchMode ? 'exitBatchMode' : 'enterBatchMode'}}" wx:if="{{canManageDishes}}">
      <text>{{batchMode ? '取消' : '批量'}}</text>
    </view>
  </view>

  <!-- 分类筛选 -->
  <scroll-view class="category-bar" scroll-x enable-flex>
    <view class="category-item {{currentCategory === item.value ? 'active' : ''}}" wx:for="{{visibleCategories}}" wx:key="value" data-value="{{item.value}}" bind:tap="onCategoryTap">
      <text>{{item.label}}</text>
    </view>
  </scroll-view>

  <!-- 回收站面板 -->
  <view class="trash-panel" wx:if="{{showTrash}}">
    <view class="trash-header">
      <text class="trash-title">🗑 回收站</text>
      <text class="trash-count">{{trashList.length}} 道已删除</text>
    </view>
    <view class="trash-list" wx:if="{{trashList.length > 0}}">
      <view class="trash-item" wx:for="{{trashList}}" wx:key="_id">
        <text class="trash-item-name">{{item.name}}</text>
        <view class="trash-actions">
          <text class="trash-restore" data-id="{{item._id}}" bind:tap="restoreDish">恢复</text>
          <text class="trash-hard" data-id="{{item._id}}" bind:tap="hardDeleteDish">彻底删除</text>
        </view>
      </view>
    </view>
    <view class="trash-empty" wx:else><text>回收站为空</text></view>
  </view>

  <!-- 菜品列表 -->
  <view class="dish-list" wx:if="{{dishList.length > 0}}">
    <dish-card wx:for="{{dishList}}" wx:key="_id" dish="{{item}}" batchMode="{{batchMode}}" selected="{{selectedIds[item._id]}}" bind:tap="goDishDetail" data-id="{{item._id}}" bind:batchtap="toggleBatchSelect" data-id="{{item._id}}" bind:longpress="quickDelete"></dish-card>
  </view>

  <empty-state wx:elif="{{!loading}}" text="暂无菜品" subText="点击右下角添加你的第一道菜" btnText="添加菜品" bind:btntap="goAddDish"></empty-state>

  <!-- 加载中 -->
  <view class="loading" wx:if="{{loading}}">
    <text class="loading-text">加载中...</text>
  </view>

  <!-- 没有更多 -->
  <view class="no-more" wx:if="{{noMore && dishList.length > 0}}">
    <text class="no-more-text">— 没有更多了 —</text>
  </view>

  <!-- 批量操作底部栏 -->
  <view class="batch-bar" wx:if="{{batchMode}}">
    <view class="batch-bar-row">
      <view class="batch-select-actions">
        <text class="batch-select-link" bind:tap="batchSelectAll">全选</text>
        <text class="batch-select-link" bind:tap="batchDeselectAll">取消</text>
      </view>
      <text class="batch-selected-count">已选 {{selectedCount}} 道</text>
    </view>
    <view class="batch-bar-row">
      <text class="batch-label">分类</text>
      <picker mode="selector" range="{{batchCategoryOptions}}" value="{{batchCategoryIndex}}" bindchange="onBatchCategoryChange">
        <view class="batch-picker">{{batchCategory}} ▼</view>
      </picker>
      <view class="btn-primary batch-apply-btn" bind:tap="applyBatchCategory"><text>应用</text></view>
    </view>
    <view class="batch-bar-row">
      <text class="batch-label">可见</text>
      <switch checked="{{batchPublic}}" bindchange="toggleBatchPublic" color="#FF6B35"></switch>
      <text class="batch-label">{{batchPublic ? '公开' : '家庭'}}</text>
      <view class="btn-primary batch-apply-btn" bind:tap="applyBatchPublic"><text>应用</text></view>
    </view>
    <view class="batch-bar-row">
      <view class="batch-delete-btn" bind:tap="applyBatchDelete"><text>🗑 批量移入回收站</text></view>
    </view>
  </view>
</view>

  <!-- 浮动添加按钮 -->
  <view class="fab" bind:tap="goAddDish" wx:if="{{canManageDishes}}">
    <text class="fab-text">+</text>
  </view>
