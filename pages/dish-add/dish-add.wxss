/* pages/dish-add/dish-add.wxss */
.container {
  padding: 24rpx;
  padding-bottom: 200rpx;
}

/* Tab栏 */
.tab-bar {
  display: flex;
  background: #FFFFFF;
  box-shadow: 0 2rpx 8rpx rgba(255, 107, 53, 0.06);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 28rpx 0;
  font-size: 30rpx;
  color: #999999;
  position: relative;
}

.tab-item.active {
  color: #FF6B35;
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 6rpx;
  border-radius: 3rpx;
  background: #FF6B35;
}

/* 表单 */
.card {
  margin-bottom: 24rpx;
}

.form-group {
  margin-bottom: 32rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 16rpx;
}

.form-label-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.form-label-row .form-label {
  margin-bottom: 0;
}

.add-link {
  font-size: 26rpx;
  color: #FF6B35;
  font-weight: 600;
}

.form-input {
  width: 100%;
  height: 80rpx;
  background: #FFF8F3;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333333;
  box-sizing: border-box;
}

.form-textarea {
  width: 100%;
  min-height: 120rpx;
  background: #FFF8F3;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: #333333;
  box-sizing: border-box;
}

.picker-value {
  height: 80rpx;
  line-height: 80rpx;
  background: #FFF8F3;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333333;
}

/* 场景选择 */
.scene-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.scene-item {
  flex: 1;
  min-width: 140rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 16rpx;
  background: #FFF8F3;
  border-radius: 16rpx;
  border: 2rpx solid transparent;
}

.scene-item.active {
  border-color: #FF6B35;
  background: rgba(255, 107, 53, 0.08);
}

.scene-emoji {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.scene-name {
  font-size: 26rpx;
  color: #555555;
}

.scene-item.active .scene-name {
  color: #FF6B35;
  font-weight: 600;
}

/* 人数选择 */
.people-selector {
  display: flex;
  align-items: center;
  gap: 32rpx;
}

.people-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #FFF8F3;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: #FF6B35;
  font-weight: 600;
}

.people-count {
  font-size: 36rpx;
  font-weight: 700;
  color: #333333;
}

/* 难度选择 */
.difficulty-selector {
  display: flex;
  gap: 16rpx;
}

.difficulty-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  background: #FFF8F3;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #666666;
  border: 2rpx solid transparent;
}

.difficulty-item.active {
  border-color: #FF6B35;
  background: rgba(255, 107, 53, 0.08);
  color: #FF6B35;
  font-weight: 600;
}

/* 多图上传网格 */
.images-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.image-cell {
  position: relative;
  width: 200rpx;
  height: 200rpx;
}

.image-cell .preview-image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 16rpx;
}

.image-cell .remove-image {
  position: absolute;
  top: -12rpx;
  right: -12rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #E74C3C;
  color: #FFFFFF;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 封面标记 */
.cover-badge {
  position: absolute;
  top: 8rpx;
  left: 8rpx;
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
  background: #FF6B35;
}

.cover-badge text {
  font-size: 20rpx;
  color: #FFFFFF;
  font-weight: 600;
}

/* 设为封面 */
.set-cover-btn {
  position: absolute;
  bottom: 8rpx;
  left: 8rpx;
  right: 8rpx;
  padding: 6rpx 0;
  border-radius: 8rpx;
  background: rgba(0,0,0,0.45);
  text-align: center;
}

.set-cover-btn text {
  font-size: 20rpx;
  color: #FFFFFF;
}

.upload-btn {
  width: 200rpx;
  height: 200rpx;
  border-radius: 16rpx;
  border: 2rpx dashed #F7C59F;
  background: #FFF8F3;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.upload-icon {
  font-size: 56rpx;
  color: #F7C59F;
}

.upload-text {
  font-size: 24rpx;
  color: #999999;
  margin-top: 8rpx;
}

/* 标签输入 */
.tags-input-area {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  align-items: center;
  background: #FFF8F3;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
}

.tag-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 20rpx;
  background: rgba(255, 107, 53, 0.1);
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #FF6B35;
}

.tag-remove {
  font-size: 20rpx;
  color: #999999;
}

.tag-input {
  flex: 1;
  min-width: 200rpx;
  font-size: 28rpx;
  color: #333333;
  background: transparent;
}

/* 食材表单 */
.ingredient-form {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.ingredient-name-input {
  flex: 2;
  height: 72rpx;
  background: #FFF8F3;
  border-radius: 10rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #333333;
}

.ingredient-amount-input {
  flex: 1;
  height: 72rpx;
  background: #FFF8F3;
  border-radius: 10rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #333333;
}

/* 步骤表单 */
.step-form {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.step-index {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #FF6B35;
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-top: 8rpx;
}

.step-textarea {
  flex: 1;
  min-height: 80rpx;
  background: #FFF8F3;
  border-radius: 10rpx;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
  color: #333333;
}

.remove-btn {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #E74C3C;
  font-size: 28rpx;
  flex-shrink: 0;
  margin-top: 8rpx;
}

/* AI结果 */
.ai-result-card {
  margin-bottom: 24rpx;
}

.ai-dish-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #333333;
  margin-bottom: 8rpx;
}

.ai-dish-desc {
  font-size: 26rpx;
  color: #666666;
  margin-bottom: 12rpx;
  line-height: 1.5;
}

.ai-dish-info {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 12rpx;
}

.ai-dish-ingredients {
  font-size: 26rpx;
  color: #555555;
  margin-bottom: 8rpx;
}

.ingredient-label {
  font-weight: 600;
  color: #333333;
}

.ingredient-text {
  color: #666666;
}

.ai-dish-steps {
  font-size: 26rpx;
  color: #555555;
  margin-bottom: 16rpx;
}

.step-line {
  margin-top: 8rpx;
  line-height: 1.5;
}

.add-to-lib-btn {
  margin-top: 16rpx;
  text-align: center;
  padding: 16rpx 0;
  font-size: 28rpx;
}

.generate-btn {
  text-align: center;
  padding: 24rpx 0;
  margin-top: 16rpx;
}

.ai-loading {
  display: flex;
  justify-content: center;
  padding: 60rpx 0;
}

.ai-loading-text {
  font-size: 30rpx;
  color: #FF6B35;
}

/* 底部保存 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: #FFFFFF;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.06);
  z-index: 100;
}

.save-btn {
  text-align: center;
  padding: 24rpx 0;
  border-radius: 48rpx;
}

.public-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.public-text {
  display: flex;
  flex-direction: column;
}
.public-text .form-label {
  margin-bottom: 0;
}
.form-hint {
  font-size: 22rpx;
  color: #BBB;
  margin-top: 4rpx;
}
