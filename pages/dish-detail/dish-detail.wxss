/* pages/dish-detail/dish-detail.wxss */
.container {
  padding: 0;
  padding-bottom: 160rpx;
}

/* 大图 */
.dish-hero {
  position: relative;
  width: 100%;
  height: 400rpx;
  overflow: hidden;
}

.dish-hero-empty {
  background: linear-gradient(135deg, #FF6B35, #FF8B5E);
}

.hero-swiper {
  width: 100%;
  height: 100%;
}

.hero-image {
  width: 100%;
  height: 100%;
}

.hero-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 40rpx 32rpx 32rpx;
  background: linear-gradient(transparent, rgba(0,0,0,0.6));
}

.hero-overlay-plain {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 40rpx 32rpx 32rpx;
}

.dish-name {
  font-size: 40rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 12rpx;
}

.dish-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.tag {
  display: inline-block;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  background: rgba(255, 255, 255, 0.3);
  color: #FFFFFF;
}

/* 信息栏 */
.info-bar {
  display: flex;
  align-items: center;
  justify-content: space-around;
  margin: 24rpx;
  padding: 24rpx;
}

.info-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.info-label {
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 8rpx;
}

.info-value {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
}

.difficulty-easy { color: #27AE60; }
.difficulty-medium { color: #F39C12; }
.difficulty-hard { color: #E74C3C; }

.info-divider {
  width: 1rpx;
  height: 48rpx;
  background: #FFE8D6;
}

/* 食材 */
.section {
  padding: 0 24rpx;
  margin-bottom: 24rpx;
}

.ingredient-list {
  padding: 12rpx 28rpx;
}

.ingredient-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #FFF0E0;
}

.ingredient-item:last-child {
  border-bottom: none;
}

.ingredient-name {
  font-size: 28rpx;
  color: #333333;
}

.ingredient-amount {
  font-size: 26rpx;
  color: #999999;
}

/* 步骤 */
.steps {
  margin-top: 8rpx;
}

.step-card {
  display: flex;
  align-items: flex-start;
  padding: 24rpx 28rpx;
}

.step-number {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FF6B35, #FF8B5E);
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 20rpx;
}

.step-content {
  flex: 1;
  padding-top: 6rpx;
}

.step-text {
  font-size: 28rpx;
  color: #555555;
  line-height: 1.6;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: #FFFFFF;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.06);
  z-index: 100;
}

.bottom-btn {
  flex: 1;
  margin: 0 8rpx;
  height: 80rpx;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
}

.bottom-btn.outline {
  border: 2rpx solid #FF6B35;
  color: #FF6B35;
  background: transparent;
}

.bottom-btn.primary {
  background: linear-gradient(135deg, #FF6B35, #FF8B5E);
  color: #FFFFFF;
}

.bottom-btn.danger {
  background: #FFF;
  color: #E74C3C;
  border: 2rpx solid #E74C3C;
}

.loading-page {
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 100vh;
  color: #999999;
}

/* 评分 */
.rating-card {
  padding: 24rpx 28rpx;
  margin-bottom: 24rpx;
}
.rating-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}
.rating-row:last-child { margin-bottom: 0; }
.rating-label { font-size: 28rpx; color: #555; width: 120rpx; }
.star { font-size: 32rpx; color: #E0E0E0; }
.star.active { color: #FFB800; }
.stars-picker .star.pick { font-size: 40rpx; margin-right: 8rpx; }
.star.pick:active { transform: scale(1.2); }
.rating-num { font-size: 28rpx; font-weight: 600; color: #FF6B35; }
.rating-count { font-size: 24rpx; color: #BBB; }
