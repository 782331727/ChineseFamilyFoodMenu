/* pages/preorder/preorder.wxss */
.container {
  padding: 24rpx;
  padding-bottom: 200rpx;
}

.card {
  margin-bottom: 24rpx;
}

.form-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 16rpx;
}

/* 日期选择 */
.date-scroll {
  display: flex;
  white-space: nowrap;
}

.date-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 32rpx;
  margin-right: 16rpx;
  border-radius: 16rpx;
  background: #FFF8F3;
  min-width: 120rpx;
}

.date-item.active {
  background: linear-gradient(135deg, #FF6B35, #FF8B5E);
}

.date-label {
  font-size: 28rpx;
  color: #555555;
  font-weight: 600;
}

.date-item.active .date-label {
  color: #FFFFFF;
}

.date-week {
  font-size: 22rpx;
  color: #999999;
  margin-top: 4rpx;
}

.date-item.active .date-week {
  color: rgba(255, 255, 255, 0.8);
}

/* 餐次选择 */
.meal-selector {
  display: flex;
  gap: 16rpx;
}

.meal-option {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 0;
  border-radius: 16rpx;
  background: #FFF8F3;
  border: 2rpx solid transparent;
}

.meal-option.active {
  border-color: #FF6B35;
  background: rgba(255, 107, 53, 0.08);
}

.meal-emoji {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.meal-name {
  font-size: 26rpx;
  color: #555555;
}

.meal-option.active .meal-name {
  color: #FF6B35;
  font-weight: 600;
}

/* 菜品网格 */
.dish-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  gap: 12rpx;
}

.dish-grid-item {
  position: relative;
  width: 31%;
  border-radius: 16rpx;
  overflow: hidden;
  background: #FFF8F3;
  border: 3rpx solid transparent;
  box-sizing: border-box;
}

.dish-grid-item.selected {
  border-color: #FF6B35;
}

.grid-dish-image {
  width: 100%;
  height: 160rpx;
}

.grid-dish-name {
  display: block;
  font-size: 24rpx;
  color: #333333;
  text-align: center;
  padding: 8rpx;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.check-mark {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #FF6B35;
  color: #FFFFFF;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.empty-text {
  text-align: center;
  padding: 40rpx;
  color: #999999;
  font-size: 28rpx;
}

/* 备注 */
.form-textarea {
  width: 100%;
  min-height: 100rpx;
  background: #FFF8F3;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: #333333;
  box-sizing: border-box;
}

/* 已选摘要 */
.selected-summary {
  text-align: center;
  padding: 16rpx;
}

.summary-text {
  font-size: 28rpx;
  color: #FF6B35;
  font-weight: 600;
}

/* 底部 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: #FFFFFF;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.06);
  z-index: 100;
}

.submit-btn {
  text-align: center;
  padding: 24rpx 0;
  border-radius: 48rpx;
}

.submit-btn.disabled {
  opacity: 0.5;
}

/* 搜索 */
.search-bar-sm {
  display: flex;
  align-items: center;
  background: #FFF8F3;
  border-radius: 12rpx;
  padding: 0 16rpx;
  margin-bottom: 16rpx;
  height: 64rpx;
}
.search-input-sm {
  flex: 1;
  font-size: 26rpx;
  color: #333;
}
.search-clear-sm {
  font-size: 24rpx;
  color: #CCC;
  padding: 8rpx;
}

/* 菜品上的预定人 */
.grid-dish-booker {
  display: block;
  font-size: 18rpx;
  color: #FF6B35;
  text-align: center;
  padding: 0 4rpx 4rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.preorder-note {
  text-align: center;
  padding: 16rpx 0;
  margin-bottom: 120rpx;
}
.preorder-note text {
  font-size: 22rpx;
  color: #CCC;
}

/* 他人已预定 */
.others-card {
  margin-bottom: 24rpx;
}
.others-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}
.others-chip {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: #FFF0E0;
  border-radius: 16rpx;
  padding: 8rpx 16rpx;
}
.others-avatar {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
}
.others-text {
  font-size: 22rpx;
  color: #FF6B35;
}
