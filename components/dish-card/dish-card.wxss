/* components/dish-card/dish-card.wxss */
.dish-card {
  display: flex;
  background: #FFFFFF;
  border-radius: 20rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 53, 0.08);
}

.dish-image {
  width: 200rpx;
  height: 200rpx;
  flex-shrink: 0;
  background: #FFF8F3;
}

.dish-info {
  flex: 1;
  padding: 20rpx 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.dish-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  line-height: 1.3;
}

.dish-meta {
  display: flex;
  align-items: center;
  margin-top: 8rpx;
}

.meta-item {
  font-size: 24rpx;
  color: #999999;
}

.difficulty-easy { color: #27AE60; }
.difficulty-medium { color: #F39C12; }
.difficulty-hard { color: #E74C3C; }

.meta-divider {
  margin: 0 12rpx;
  color: #CCCCCC;
  font-size: 24rpx;
}

.dish-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 12rpx;
}

/* 批量选择 */
.batch-check {
  display: flex;
  align-items: center;
  padding: 0 16rpx;
}
.batch-check-circle {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  border: 3rpx solid #F7C59F;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #FFF;
  flex-shrink: 0;
}
.batch-check-circle.checked {
  background: #FF6B35;
  border-color: #FF6B35;
}

.tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 16rpx;
  font-size: 20rpx;
  background: rgba(255, 107, 53, 0.1);
  color: #FF6B35;
}
